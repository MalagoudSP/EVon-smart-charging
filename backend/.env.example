# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/evon_db

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256

# API Configuration
CORS_ORIGINS=http://localhost:3000

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000

# ML Model Configuration
MODEL_UPDATE_INTERVAL=3600  # Update models every hour
PREDICTION_LOOKBACK_HOURS=24
PREDICTION_FORWARD_HOURS=24

# External APIs
OPEN_WEATHER_MAP_API_KEY=your-api-key
OSRM_API_URL=https://router.project-osrm.org

# Email (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
