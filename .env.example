# Example environment variables for development
# Replace values before running the app

# Google Maps JavaScript API key (optional — app falls back to OpenStreetMap)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SQLite (dev) example. For production replace with a managed Postgres/MySQL URL.
DATABASE_URL="file:./dev.db"

# Optional: for production Postgres example
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
